---
import Layout from "../../layouts/Layout.astro";
---

<script>
  import { quadRenderPass, glCanvas } from "@radiancejs/gl";
  import { incrementRenderCount } from "../../components/renderCount";

  const canvas = document.querySelector("canvas")!;

  const leftShader = glCanvas({
    canvas,
    fragment: /* glsl */ `
			void main() {
				gl_FragColor = vec4(1, 0, 0, 1);
			}
		`,
    renderMode: "manual",
  });

  const rightShader = quadRenderPass(leftShader.gl, {
    fragment: /* glsl */ `
			void main() {
				gl_FragColor = vec4(0, 1, 0, 1);
			}
		`,
  });

  leftShader.onAfterRender(incrementRenderCount);
  rightShader.onAfterRender(incrementRenderCount);

  const { gl } = leftShader;
  gl.enable(gl.SCISSOR_TEST);

  gl.scissor(0, 0, gl.drawingBufferWidth / 2, gl.drawingBufferHeight);
  leftShader.render();

  gl.scissor(gl.drawingBufferWidth / 2, 0, gl.drawingBufferWidth / 2, gl.drawingBufferHeight);
  rightShader.render();
</script>

<Layout title="Scissor">
  <canvas></canvas>
</Layout>

<style>
  canvas {
    aspect-ratio: 2;
  }
</style>
