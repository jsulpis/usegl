    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.16.5",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "tsdown": "0.14.1",
    "typescript": "5.8.3"
  }
}
