{
  "name": "@radiance/helpers",
  "version": "0.1.0",
  "private": true,
  "description": "Utility functions for DOM, timing, and pointer events",
  "repository": "jsulpis/usegl",
  "license": "MIT",
  "author": "Julien SULPIS",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier src --check",
